<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Activity Manager | Camp Hub</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="container">
    <a href="/" class="back-link" style="display:inline-block; margin-bottom: 16px;">← Back to Dashboard</a>
    <h1>Activity Rules &amp; Constraints</h1>

    <div class="upload-banner">
        <h3>Bulk Upload Rules</h3>
        <p><small>CSV Headers: <strong>Name, SideOfCamp, MaxCapacity</strong></small></p>
        <form action="/upload-activity-rules" method="POST" enctype="multipart/form-data">
            <input type="file" name="file" accept=".csv" required>
            <button type="submit" class="btn btn-primary">Import Rules CSV</button>
        </form>
    </div>

    </div><!-- /container -->

    <div class="container">
    <div class="rules-card">
        <div class="table-scroll">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Activity Name</th>
                    <th>Camp Side</th>
                    <th>Max Capacity</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                <% activities.forEach(act => { %>
                <form action="/update-activity-capacity" method="POST">
                    <input type="hidden" name="ActivityName" value="<%= act.Name %>">
                    <tr class="<%= act.SideOfCamp === 'Sports' ? 'sports-row' : 'enrich-row' %>">
                        <td><strong><%= act.Name %></strong></td>
                        <td>
                            <select name="SideOfCamp">
                                <option value="Enrichment">Enrichment</option>
                                <option value="Sports">Sports</option>
                            </select>
                        </td>
                        <td><input type="number" name="MaxCapacity" value="<%= act.MaxCapacity %>"></td>
                        <td><button type="submit">Save</button></td>
                    </tr>
                </form>
                <% }) %>
            </tbody>
        </table>
        </div>
    </div>
    </div><!-- /container -->
</body>
</html>