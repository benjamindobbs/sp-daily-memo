<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Counselor: <%= counselor.FirstName %>
            <%= counselor.LastName %>
    </title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .profile-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
        }

        /* Fixed Header Section */
        .counselor-header {
            background: var(--primary);
            color: white;
            padding: 40px;
            border-radius: 16px;
            margin-bottom: 30px;
            position: relative;
            overflow: hidden;
        }

        .duty-strip {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            background: rgba(255, 255, 255, 0.1);
            padding: 20px;
            border-radius: 12px;
            margin-top: 20px;
            backdrop-filter: blur(5px);
        }

        .duty-box small {
            display: block;
            text-transform: uppercase;
            font-size: 0.7rem;
            opacity: 0.8;
            margin-bottom: 4px;
        }

        .duty-box strong {
            font-size: 1.1rem;
        }

        /* Grid for Schedule and Roster */
        .dashboard-layout {
            display: grid;
            grid-template-columns: 350px 1fr;
            gap: 30px;
        }

        .schedule-list {
            list-style: none;
            padding: 0;
        }

        .schedule-card {
            padding: 15px;
            border-left: 4px solid var(--primary);
            background: #f8fafc;
            margin-bottom: 12px;
            border-radius: 0 8px 8px 0;
        }

        /* Responsive Roster Table */
        .roster-card {
            background: white;
            border-radius: 12px;
            padding: 25px;
            box-shadow: var(--shadow);
            border: 1px solid var(--border-color);
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th {
            text-align: left;
            padding: 12px;
            border-bottom: 2px solid #edf2f7;
            color: #64748b;
            font-size: 0.8rem;
            text-transform: uppercase;
        }

        td {
            padding: 15px 12px;
            border-bottom: 1px solid #f1f5f9;
        }

        @media (max-width: 900px) {
            .dashboard-layout {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>

<body>

    <nav class="nav-bar">
        <a href="/counselor-directory" class="nav-btn">⬅ Back to Staff Directory</a>
        <a href="/attendance" class="nav-btn">&#128203; Attendance</a>
    </nav>

    <div class="profile-container">
        <header class="counselor-header">
            <span class="tag <%= counselor.HomeGroupColor %>"
                style="background: white; color: var(--primary); font-weight: 800;">
                <%= counselor.HomeGroupColor %> Group
            </span>
            <h1 style="margin: 15px 0 5px 0; font-size: 2.5rem;">
                <%= counselor.FirstName %>
                    <%= counselor.LastName %>
            </h1>

            <div class="duty-strip">
                <div class="duty-box">
                    <small>🚌 Bus Route</small>
                    <strong>
                        <%= counselor.BusRoute || 'None' %>
                    </strong>
                </div>
                <div class="duty-box">
                    <small>⏰ Extended Care</small>
                    <strong>
                        <%= counselor.ExtendedHours || 'None' %>
                    </strong>
                </div>
                <div class="duty-box">
                    <small>📋 Schedule Type</small>
                    <strong>
                        <%= counselor.ScheduleType %>
                    </strong>
                </div>
            </div>
        </header>

        <div class="dashboard-layout">
            <section>
                <h3 style="margin-bottom: 20px;">Daily Assignments</h3>
                <div class="schedule-list">
                    <% if (schedule.length> 0) { %>
                        <% schedule.forEach(s=> { %>
                            <div class="schedule-card">
                                <small style="color: var(--primary); font-weight: 700;">PERIOD <%= s.PeriodNumber %>
                                        </small>
                                <div style="font-weight: 600; margin: 4px 0;">
                                    <%= s.ActivityName %>
                                </div>
                                <div style="font-size: 0.85rem; color: #64748b;">📍 <%= s.Location || 'Main Field' %>
                                </div>
                            </div>
                            <% }) %>
                                <% } else { %>
                                    <p class="card" style="text-align: center; color: var(--text-muted);">No assigned
                                        classes.</p>
                                    <% } %>
                </div>
            </section>

            <section class="roster-card">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                    <h3 style="margin: 0;">Group Roster</h3>
                    <span class="tag" style="background: #e2e8f0; color: #475569;">
                        <%= campers.length %> Campers
                    </span>
                </div>

                <table>
                    <thead>
                        <tr>
                            <th>Camper Name</th>
                            <th>Age</th>
                            <th>Bus</th>
                            <th>Extended</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (campers.length> 0) { %>
                            <% campers.forEach(camper=> { %>
                                <tr>
                                    <td>
                                        <a href="/search?name=<%= encodeURIComponent(camper.FirstName + ' ' + camper.LastName) %>"
                                           style="text-decoration: none; color: var(--primary); font-weight: 500;">
                                            <%= camper.FirstName %>
                                            <%= camper.LastName %>
                                        </a>
                                    </td>
                                    <td>
                                        <%= camper.Age %>
                                    </td>
                                    <td><small>
                                            <%= camper.BusRoute ? '🚌 ' + camper.BusRoute : '—' %>
                                        </small></td>
                                    <td>
                                        <% if (camper.ExtendedHours==='Both' ) { %>
                                            <span class="tag"
                                                style="background: #dcfce7; color: #166534; font-size: 0.7rem;">AM &
                                                PM</span>
                                            <% } else if (camper.ExtendedHours) { %>
                                                <span class="tag"
                                                    style="background: #fef9c3; color: #854d0e; font-size: 0.7rem;">
                                                    <%= camper.ExtendedHours %>
                                                </span>
                                                <% } else { %>
                                                    <span style="color: #cbd5e1; font-size: 0.8rem;">None</span>
                                                    <% } %>
                                    </td>
                                </tr>
                                <% }) %>
                                    <% } else { %>
                                        <tr>
                                            <td colspan="4"
                                                style="text-align: center; padding: 40px; color: var(--text-muted); font-style: italic;">
                                                No campers assigned to this group yet.
                                            </td>
                                        </tr>
                                        <% } %>
                    </tbody>
                </table>
            </section>
        </div>
    </div>
</body>

</html>