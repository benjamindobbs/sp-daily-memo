<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Camp Hub | Dashboard</title>
    <link rel="stylesheet" href="/css/style.css">
    <script src="/js/nav.js" defer></script>
</head>
<body>

    <nav class="nav-bar">
        <a href="/" class="nav-btn primary">🏠 Hub</a>
        <a href="/master-schedule" class="nav-btn">📅 Master Schedule</a>
        <a href="/search" class="nav-btn">🔍 Camper Lookup</a>
        <a href="/counselor-directory" class="nav-btn">👤 Counselor Lookup</a>
        <a href="/staff-lookup" class="nav-btn">&#128101; Staff Lookup</a>
        <a href="/swap-tool" class="nav-btn">🔄 Swap Tools</a>
        <a href="/promotions" class="nav-btn">🔔 Promotions</a>
        <a href="/attendance" class="nav-btn">&#128203; Attendance</a>
        <a href="/settings" class="nav-btn" style="margin-left: auto;">⚙️ Data Management</a>
    </nav>

    <div class="container">
        <header class="header-flex">
            <div>
                <h1>Welcome back, Director</h1>
                <p class="text-muted">Here is what's happening at camp today.</p>
            </div>
        </header>

        <% if (waitlistCount > 0) { %>
            <div class="promo-alert">
                <span><strong>Promotion Available:</strong> There are <%= waitlistCount %> campers eligible for open spots!</span>
                <a href="/promotions" class="btn btn-success">View Promotions</a>
            </div>
        <% } %>

        <div class="stats-grid">
            <div class="card stat-card">
                <span class="stat-number"><%= camperTotal %></span>
                <span class="stat-label">Active Campers</span>
            </div>
            <div class="card stat-card">
                <span class="stat-number"><%= staffTotal %></span>
                <span class="stat-label">Total Staff</span>
            </div>
            <div class="card stat-card">
                <span class="stat-number"><%= activityCount %></span>
                <span class="stat-label">Activities Running</span>
            </div>
        </div>

        <div class="quick-tasks mt-20">
            <div class="card">
                <h3>Quick Tasks</h3>
                <ul>
                    <li>
                        <a href="/settings">Adjust Activity Capacities →</a>
                    </li>
                    <li>
                        <a href="/settings">Upload New CSV Data →</a>
                    </li>
                </ul>
            </div>
            <div class="card">
                <h3>System Status</h3>
                <p class="text-muted" style="font-size: 0.9rem;">
                    Database: <span style="color: var(--success);">● Operational</span><br>
                    Current Season: Summer 2026<br>
                    Last Backup: Today, 8:00 AM
                </p>
            </div>
        </div>
    </div>

</body>
</html>