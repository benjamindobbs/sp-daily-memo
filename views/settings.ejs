<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Settings & Data Management | Camp Hub</title>
    <link rel="stylesheet" href="/css/style.css">
    <script src="/js/nav.js" defer></script>
</head>

<body>

    <nav class="nav-bar">
        <a href="/" class="nav-btn">🏠 Hub</a>
        <a href="/master-schedule" class="nav-btn">📅 Schedule</a>
        <a href="/settings" class="nav-btn primary">⚙️ Settings</a>
        <a href="/attendance" class="nav-btn">&#128203; Attendance</a>
    </nav>

    <div class="container">
        <h1>System Settings</h1>

        <% if (alertMessage) { %>
            <div class="alert">
                <%= alertMessage %>
            </div>
            <% } %>

                <div class="settings-grid">

                    <section class="settings-card">
                        <h2>🎾 Activity Manager</h2>
                        <p class="text-muted">Manage locations and capacity constraints.</p>

                        <div class="upload-box">
                            <h4 style="margin-top:0; font-size: 0.9rem;">Bulk Upload Activities</h4>
                            <p class="text-muted" style="font-size: 0.7rem; margin-bottom: 10px;">
                                Headers: <strong>Name | SideOfCamp | MaxCapacity</strong>
                            </p>
                            <form action="/upload-activity-rules" method="POST" enctype="multipart/form-data" class="inline-form">
                                <input type="file" name="file" accept=".csv" required style="font-size: 0.75rem; flex: 1;">
                                <button type="submit" class="btn primary btn-small">Import CSV</button>
                            </form>
                            <form action="/clear-activities" method="POST"
                                onsubmit="return confirm('Delete ALL activities? This cannot be undone.');"
                                style="margin-top: 10px;">
                                <button type="submit" class="settings-link-btn">🗑️ Clear All Activities</button>
                            </form>
                        </div>

                        <form action="/add-activity" method="POST" class="inline-form" style="margin-bottom: 20px;">
                            <input type="text" name="activityName" placeholder="Activity name" required style="flex: 2; min-width: 120px;">
                            <select name="side" style="flex: 1; min-width: 100px;">
                                <option value="Enrichment">Enrichment</option>
                                <option value="Sports">Sports</option>
                            </select>
                            <button type="submit" class="btn primary btn-small">Add</button>
                        </form>

                        <div style="margin-bottom: 15px;">
                            <input type="text" id="activitySearch" onkeyup="filterActivities()"
                                placeholder="🔍 Filter activity list..."
                                style="width: 100%; padding: 8px; border-radius: 6px; border: 1px solid #cbd5e1; font-size: 0.9rem;">
                        </div>

                        <div style="max-height: 400px; overflow-y: auto; border: 1px solid #f1f5f9; border-radius: 8px;">
                            <table id="activityTable" class="settings-table activity-table">
                                <thead>
                                    <tr>
                                        <th>Activity</th>
                                        <th>Side</th>
                                        <th>Max</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% activities.forEach(act=> { %>
                                        <tr
                                            class="activity-row <%= act.SideOfCamp === 'Sports' ? 'row-sports' : 'row-enrichment' %>">
                                            <td class="act-name"><strong>
                                                    <%= act.Name %>
                                                </strong></td>
                                            <td>
                                                <%= act.SideOfCamp %>
                                            </td>

                                            <td>
                                                <form action="/update-activity" method="POST"
                                                    style="display: flex; align-items: center; gap: 5px;">
                                                    <input type="hidden" name="activityName" value="<%= act.Name %>">
                                                    <input type="number" name="maxCapacity"
                                                        value="<%= act.MaxCapacity %>"
                                                        style="width: 60px; padding: 4px; border: 1px solid #cbd5e1; border-radius: 4px; font-size: 0.85rem;"
                                                        title="Max Capacity">
                                                    <button type="submit" title="Save Capacity"
                                                        style="background: none; border: none; cursor: pointer; font-size: 1rem; padding: 0;">
                                                        💾
                                                    </button>
                                                </form>
                                            </td>

                                            <td>
                                                <form action="/delete-activity/<%= encodeURIComponent(act.Name) %>"
                                                    method="POST" onsubmit="return confirm('Delete activity?');">
                                                    <button type="submit"
                                                        style="background:none; border:none; cursor:pointer;">🗑️</button>
                                                </form>
                                            </td>
                                        </tr>
                                        <% }) %>
                                </tbody>
                            </table>
                        </div>
                    </section>

                    <script>
                        function filterActivities() {
                            const input = document.getElementById('activitySearch');
                            const filter = input.value.toLowerCase();
                            const rows = document.querySelectorAll('.activity-row');

                            rows.forEach(row => {
                                const name = row.querySelector('.act-name').textContent.toLowerCase();
                                if (name.includes(filter)) {
                                    row.style.display = "";
                                } else {
                                    row.style.display = "none";
                                }
                            });
                        }
                    </script>

                    <div style="display: flex; flex-direction: column; gap: 30px;">
                        <section class="settings-card">
                            <h2>CSV Data Imports</h2>

                            <div class="upload-section"
                                style="margin-bottom: 25px; padding-bottom: 15px; border-bottom: 1px solid #eee;">
                                <h4 style="margin-bottom: 5px;">Counselors</h4>
                                <p class="text-muted" style="font-size: 0.75rem; margin-bottom: 10px;">
                                    Required Headers: <strong>FirstName, LastName, HomeGroupColor, P1, P2, P3, P4, P5,
                                        P6</strong>
                                </p>
                                <form action="/upload-counselors" method="POST" enctype="multipart/form-data" style="display: flex; flex-direction: column; gap: 10px;">
                                    <input type="file" name="file" accept=".csv" required style="font-size: 0.85rem;">
                                    <button type="submit" class="btn primary btn-small" style="width: fit-content;">Import Counselors</button>
                                </form>
                                <form action="/clear-counselors" method="POST" onsubmit="return confirm('Delete ALL counselors?');" style="margin-top: 5px;">
                                    <button type="submit" class="settings-link-btn">🗑️ Clear All Counselors</button>
                                </form>
                            </div>

                            <div class="upload-section"
                                style="margin-bottom: 25px; padding-bottom: 15px; border-bottom: 1px solid #eee;">
                                <h4 style="margin-bottom: 5px;">Unit Leaders & Instructors</h4>
                                <p class="text-muted" style="font-size: 0.75rem; margin-bottom: 10px;">
                                    Required Headers: <strong>FirstName, LastName, HomeGroupColor, StaffType, P1,
                                        P2...</strong>
                                </p>
                                <form action="/upload-staff" method="POST" enctype="multipart/form-data" style="display: flex; flex-direction: column; gap: 10px;">
                                    <input type="file" name="file" accept=".csv" required style="font-size: 0.85rem;">
                                    <button type="submit" class="btn primary btn-small" style="width: fit-content;">Import Staff List</button>
                                </form>
                                <form action="/clear-staff" method="POST" onsubmit="return confirm('Delete ALL general staff?');" style="margin-top: 5px;">
                                    <button type="submit" class="settings-link-btn">🗑️ Clear All Staff</button>
                                </form>
                            </div>

                            <div class="upload-section">
                                <h4>Camper Rosters</h4>
                                <p class="text-muted" style="font-size: 0.75rem; margin-bottom: 10px;">
                                    <strong>Required CSV Headers:</strong><br>
                                    FirstName, LastName, Age, HomeGroupColor, HomeGroupCounselor, BusRoute,
                                    ExtendedHours, CampLunch, P1, P2, P3, P4, P5
                                </p>
                                <form action="/upload-campers" method="POST" enctype="multipart/form-data">
                                    <input type="file" name="file" accept=".csv" required>
                                    <button type="submit" class="btn primary btn-small">Import Campers</button>
                                </form>

                                <form action="/clear-campers" method="POST" onsubmit="return confirm('Delete ALL campers?');" style="margin-top: 10px;">
                                    <button type="submit" class="settings-link-btn">🗑️ Clear All Campers</button>
                                </form>
                            </div>
                        </section>

                    </div>
                </div>
    </div>

</body>

</html>