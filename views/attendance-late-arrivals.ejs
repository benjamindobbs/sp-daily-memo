<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Late Arrivals | Camp Hub</title>
    <link rel="stylesheet" href="/css/style.css">
    <script src="/js/nav.js" defer></script>
</head>
<body>
    <nav class="nav-bar">
        <a href="/" class="nav-btn">&#127968; Hub</a>
        <a href="/master-schedule" class="nav-btn">&#128197; Master Schedule</a>
        <a href="/search" class="nav-btn">&#128269; Camper Lookup</a>
        <a href="/counselor-directory" class="nav-btn">&#128100; Counselors</a>
        <a href="/swap-tool" class="nav-btn">&#128260; Swap Tools</a>
        <a href="/attendance" class="nav-btn primary">&#128203; Attendance</a>
    </nav>

    <div class="container-lg">
        <header class="page-header">
            <a href="/attendance?date=<%= date %>" class="back-link">&#8592; Attendance</a>
            <span class="pipe-sep">|</span>
            <div>
                <h1>&#9888; Late Arrivals</h1>
                <p>Campers marked absent this morning. Check them in when they arrive.</p>
            </div>
        </header>

        <div class="date-bar">
            <label for="datePicker">Date:</label>
            <input type="date" id="datePicker" value="<%= date %>"
                   onchange="window.location='/attendance/late-arrivals?date='+this.value">
        </div>

        <div class="late-card table-scroll">
            <% if (roster.length === 0) { %>
                <div class="empty-state">
                    <span style="font-size: 2.5rem;">&#10003;</span>
                    <p style="font-weight: 600; margin-top: 10px;">No late arrivals for this date.</p>
                    <p style="font-size: 0.875rem;">All campers marked absent this morning have checked in, or no morning attendance has been taken yet.</p>
                </div>
            <% } else { %>
                <table class="late-table">
                    <thead>
                        <tr>
                            <th>Camper</th>
                            <th>Group</th>
                            <th>Schedule</th>
                            <th style="text-align:right;">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% roster.forEach(function(c) { %>
                        <tr>
                            <td>
                                <a href="/search?name=<%= encodeURIComponent(c.FirstName+' '+c.LastName) %>"
                                   class="camper-name-link">
                                    <%= c.FirstName %> <%= c.LastName %>
                                </a>
                            </td>
                            <td><span class="tag <%= c.HomeGroupColor %>"><%= c.HomeGroupColor %></span></td>
                            <td>
                                <div class="sched-mini">
                                    <% c.schedule.forEach(function(s) { %>
                                        <span class="sched-pill">P<%= s.PeriodNumber %>: <%= s.ActivityName %></span>
                                    <% }); %>
                                    <% if (c.schedule.length === 0) { %>
                                        <span style="color:var(--text-muted); font-size:0.8rem;">No schedule</span>
                                    <% } %>
                                </div>
                            </td>
                            <td style="text-align:right;">
                                <form action="/attendance/check-in" method="POST" style="display:inline;">
                                    <input type="hidden" name="date" value="<%= date %>">
                                    <input type="hidden" name="camperId" value="<%= c.CamperID %>">
                                    <button type="submit" class="btn-checkin">&#10003; Check In</button>
                                </form>
                            </td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
            <% } %>
        </div>
    </div>
</body>
</html>
