<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Schedule Swap | Camp Hub</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .swap-grid { display: grid; grid-template-columns: 400px 1fr; gap: 30px; align-items: start; }
        
        .period-card {
            padding: 15px;
            margin-bottom: 12px;
            border: 2px solid transparent;
            cursor: pointer;
            display: flex;
            justify-content: space-between;
            align-items: center;
            transition: all 0.2s;
        }
        .period-card:hover { border-color: var(--border-color); background: #f8fafc; }
        .period-card.active { 
            border-color: var(--primary); 
            background: #eff6ff; 
            box-shadow: 0 4px 6px -1px rgba(79, 70, 229, 0.1);
        }

        .option-link {
            display: block;
            padding: 15px;
            margin-bottom: 10px;
            background: white;
            border-radius: 8px;
            text-decoration: none;
            color: var(--text-main);
            border: 1px solid var(--border-color);
            transition: all 0.2s;
        }
        .option-link:hover { transform: translateX(5px); border-color: var(--primary); }
        .option-full { border-left: 5px solid var(--red-group); background: #fff1f2; }
        .option-open { border-left: 5px solid var(--green-group); }
        
        .capacity-pill { font-weight: bold; font-size: 0.85rem; padding: 4px 8px; border-radius: 4px; background: #f1f5f9; }
    </style>
</head>
<body>

    <nav class="nav-bar">
        <a href="/" class="nav-btn">🏠 Hub</a>
        <a href="/master-schedule" class="nav-btn">📅 Master Schedule</a>
        <a href="/search" class="nav-btn">🔍 Camper Lookup</a>
        <a href="/swap-tool" class="nav-btn primary">🔄 Swap Tools</a>
        <a href="/attendance" class="nav-btn">&#128203; Attendance</a>
    </nav>

    <div class="container">
        <header style="margin-bottom: 30px;">
            <h1>Camper Schedule Swapper</h1>
            <form action="/swap-tool" method="GET" style="display: flex; gap: 10px; margin-top: 15px;">
                <input type="text" name="name" placeholder="Search Camper Name..." 
                       value="<%= query || '' %>" style="flex: 1; padding: 12px; border-radius: 8px; border: 1px solid var(--border-color);">
                <button type="submit" class="btn btn-primary">Find Camper</button>
            </form>
        </header>

        <% if (camper) { %>
            <div class="swap-grid">
                <div class="sidebar">
                    <div class="card" style="margin-bottom: 20px;">
                        <span class="tag <%= camper.HomeGroupColor %>"><%= camper.HomeGroupColor %> Group</span>
                        <h2 style="margin: 10px 0 5px 0;"><%= camper.FirstName %> <%= camper.LastName %></h2>
                        <p style="color: var(--text-muted); font-size: 0.9rem;">Select a period to find a replacement activity.</p>
                    </div>

                    <% currentSchedule.forEach(p => { %>
                        <div class="card period-card" id="period-<%= p.PeriodNumber %>"
                             onclick="loadOptions('<%= camper.CamperID %>', '<%= p.PeriodNumber %>', this)">
                            <div>
                                <small style="text-transform: uppercase; color: var(--text-muted); font-weight: bold;">Period <%= p.PeriodNumber %></small>
                                <div style="font-weight: 600;"><%= p.ActivityName %></div>
                            </div>
                            <span style="color: var(--primary);">→</span>
                        </div>
                    <% }) %>
                </div>

                <div class="main-content">
                    <div id="controls-container" style="display: none;">
                        <div class="card" style="margin-bottom: 20px; display: flex; justify-content: space-between; align-items: center;">
                            <div id="side-indicator" style="font-weight: bold; color: var(--primary);"></div>
                            <input type="text" id="activitySearch" placeholder="Filter activities..." 
                                   onkeyup="filterActivities()" style="padding: 8px; border-radius: 6px; border: 1px solid var(--border-color); width: 250px;">
                        </div>
                        <div id="options-container"></div>
                    </div>
                    
                    <div id="placeholder-msg" class="card" style="text-align: center; padding: 100px; color: var(--text-muted);">
                        <span style="font-size: 3rem;">👈</span>
                        <p>Select a period on the left to see available swaps.</p>
                    </div>
                </div>
            </div>
        <% } %>
    </div>

    <script>
        let currentOptions = [];
        let activeCamperId = '<%= camper ? camper.CamperID : "" %>';
        let activePeriod = null;

        async function loadOptions(camperId, period, element) {
            // UI Updates
            document.querySelectorAll('.period-card').forEach(el => el.classList.remove('active'));
            element.classList.add('active');
            document.getElementById('controls-container').style.display = 'block';
            document.getElementById('placeholder-msg').style.display = 'none';
            
            activePeriod = period;

            // Fetch
            const res = await fetch(`/get-options/${camperId}/${period}`);
            const data = await res.json();
            currentOptions = data.options;

            document.getElementById('side-indicator').innerText = `${data.side} Options for Period ${period}`;
            renderList();
        }

        function renderList() {
            const term = document.getElementById('activitySearch').value.toLowerCase();
            const container = document.getElementById('options-container');
            
            const filtered = currentOptions.filter(opt => opt.Name.toLowerCase().includes(term));
            
            container.innerHTML = filtered.map(opt => {
                const isFull = opt.CurrentEnrollment >= opt.MaxCapacity;
                const statusClass = isFull ? 'option-full' : 'option-open';
                const warning = isFull ? "onclick=\"return confirm('This class is FULL. Promoting will move camper to WAITLIST. Proceed?')\"" : "";

                return `
                    <a href="/process-swap?camperId=${activeCamperId}&period=${activePeriod}&newActivity=${encodeURIComponent(opt.Name)}" 
                       class="option-link ${statusClass}" ${warning}>
                        <div style="display: flex; justify-content: space-between; align-items: center;">
                            <div>
                                <strong>${opt.Name}</strong>
                                ${isFull ? '<br><small style="color:var(--red-group)">Will trigger waitlist</small>' : ''}
                            </div>
                            <div class="capacity-pill">${opt.CurrentEnrollment} / ${opt.MaxCapacity}</div>
                        </div>
                    </a>
                `;
            }).join('') || '<p>No activities found.</p>';
        }

        function filterActivities() { renderList(); }
    </script>
</body>
</html>