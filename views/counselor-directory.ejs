<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Counselor Directory | Camp Hub</title>
    <link rel="stylesheet" href="/css/style.css">
    <script src="/js/nav.js" defer></script>
</head>
<body>

    <nav class="nav-bar">
        <a href="/" class="nav-btn">🏠 Hub</a>
        <a href="/master-schedule" class="nav-btn">📅 Master Schedule</a>
        <a href="/search" class="nav-btn">🔍 Camper Lookup</a>
        <a href="/counselor-directory" class="nav-btn primary">👤 Counselor Directory</a>
        <a href="/staff-lookup" class="nav-btn">&#128101; Staff Lookup</a>
        <a href="/promotions" class="nav-btn">🔔 Promotions</a>
        <a href="/attendance" class="nav-btn">&#128203; Attendance</a>
    </nav>

    <div class="directory-container">
        <header style="margin-bottom: 30px;">
            <h1>Staff Directory</h1>
            <p style="color: var(--text-muted);">Manage counselor assignments and view group rosters.</p>
            
            <div class="card dir-filters" style="margin-top: 20px;">
                <input type="text" id="staffSearch" placeholder="Filter by name..." onkeyup="filterStaff()">
                <select id="groupFilter" onchange="filterStaff()">
                    <option value="all">All Groups</option>
                    <option value="Red">Red</option>
                    <option value="Carolina">Carolina</option>
                    <option value="Green">Green</option>
                    <option value="Navy">Navy</option>
                </select>
            </div>
        </header>

        <div class="directory-grid" id="staffGrid">
            <% counselors.forEach(c => { %>
                <div class="counselor-card staff-item" 
                     data-name="<%= (c.FirstName + ' ' + c.LastName).toLowerCase() %>"
                     data-group="<%= c.HomeGroupColor %>">
                    
                    <span class="tag <%= c.HomeGroupColor %>"><%= c.HomeGroupColor %> Group</span>
                    
                    <div class="counselor-name">
                        <%= c.FirstName %> <%= c.LastName %>
                    </div>

                    <div class="assignment-info">
                        <div class="info-row">
                            <span class="info-label">🚌 Bus Route</span>
                            <span class="info-value"><%= c.BusRoute || 'N/A' %></span>
                        </div>
                        <div class="info-row">
                            <span class="info-label">⏰ Extended</span>
                            <span class="info-value"><%= c.ExtendedHours || 'None' %></span>
                        </div>
                    </div>

                    <a href="/counselor-profile/<%= c.CounselorID %>" class="profile-btn">
                        View Schedule & Roster
                    </a>
                </div>
            <% }) %>
        </div>
    </div>

    <script>
        function filterStaff() {
            const query = document.getElementById('staffSearch').value.toLowerCase();
            const group = document.getElementById('groupFilter').value;
            const items = document.querySelectorAll('.staff-item');

            items.forEach(item => {
                const nameMatch = item.dataset.name.includes(query);
                const groupMatch = group === 'all' || item.dataset.group === group;
                
                item.style.display = (nameMatch && groupMatch) ? 'flex' : 'none';
            });
        }
    </script>
</body>
</html>