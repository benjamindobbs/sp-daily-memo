<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Attendance | Camp Hub</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .att-section { margin-bottom: 36px; }
        .att-section h2 { font-size: 1rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: var(--text-muted); margin: 0 0 12px 0; }
        .att-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(210px, 1fr)); gap: 10px; }
        .att-card {
            background: white; border: 1px solid var(--border-color); border-radius: 10px;
            padding: 14px 16px; text-decoration: none; color: var(--text-main);
            display: flex; justify-content: space-between; align-items: center;
            box-shadow: var(--shadow); transition: box-shadow 0.15s, border-color 0.15s;
        }
        .att-card:hover { box-shadow: 0 6px 16px rgba(0,0,0,0.12); border-color: var(--primary); }
        .att-card-label { font-weight: 600; font-size: 0.875rem; }
        .att-card-sub { font-size: 0.75rem; color: var(--text-muted); margin-top: 2px; }
        .badge-submitted { background: #dcfce7; color: #166534; font-size: 0.68rem; font-weight: 700; padding: 3px 8px; border-radius: 20px; text-transform: uppercase; white-space: nowrap; }
        .badge-pending   { background: #f1f5f9; color: #64748b;   font-size: 0.68rem; font-weight: 700; padding: 3px 8px; border-radius: 20px; text-transform: uppercase; white-space: nowrap; }
        .date-bar { background: white; border: 1px solid var(--border-color); border-radius: 10px; padding: 14px 20px; margin-bottom: 28px; display: flex; align-items: center; gap: 16px; flex-wrap: wrap; box-shadow: var(--shadow); }
        .date-bar label { font-weight: 600; font-size: 0.875rem; }
        .date-bar input[type=date] { padding: 6px 10px; border: 1px solid #cbd5e1; border-radius: 6px; font-family: inherit; font-size: 0.875rem; }
        .alert-card { background: #fffbeb; border: 1px solid #fde68a; border-radius: 10px; padding: 14px 18px; display: flex; align-items: center; gap: 12px; margin-bottom: 24px; }
        .alert-card a { color: #92400e; font-weight: 700; }
    </style>
</head>
<body>
    <nav class="nav-bar">
        <a href="/" class="nav-btn">&#127968; Hub</a>
        <a href="/master-schedule" class="nav-btn">&#128197; Master Schedule</a>
        <a href="/search" class="nav-btn">&#128269; Camper Lookup</a>
        <a href="/counselor-directory" class="nav-btn">&#128100; Counselors</a>
        <a href="/swap-tool" class="nav-btn">&#128260; Swap Tools</a>
        <a href="/attendance" class="nav-btn primary">&#128203; Attendance</a>
    </nav>

    <div class="container" style="max-width: 1200px;">
        <header style="margin-bottom: 20px; display: flex; align-items: baseline; gap: 16px; flex-wrap: wrap;">
            <h1 style="margin: 0;">Daily Attendance</h1>
        </header>

        <div class="date-bar">
            <label for="datePicker">Date:</label>
            <input type="date" id="datePicker" value="<%= date %>" onchange="window.location='/attendance?date='+this.value">
            <% if (lateCount > 0) { %>
                <a href="/attendance/late-arrivals?date=<%= date %>"
                   style="margin-left: auto; background: #fef3c7; color: #92400e; border: 1px solid #fde68a; padding: 6px 14px; border-radius: 6px; font-weight: 700; font-size: 0.875rem; text-decoration: none;">
                    &#9888; <%= lateCount %> absent this morning &rarr; Late Arrivals
                </a>
            <% } else { %>
                <a href="/attendance/late-arrivals?date=<%= date %>"
                   style="margin-left: auto; color: var(--text-muted); font-size: 0.82rem; text-decoration: none;">
                    Late Arrivals &rarr;
                </a>
            <% } %>
        </div>

        <% if (homegroupSessions.length > 0) { %>
        <div class="att-section">
            <h2>&#127968; Homegroup Roll Call</h2>
            <div class="att-grid">
                <% homegroupSessions.forEach(function(s) { %>
                <a href="<%= s.link %>" class="att-card">
                    <div>
                        <div class="att-card-label">
                            <span class="tag <%= s.color %>" style="font-size:0.68rem; padding:1px 7px; margin-right:6px;"><%= s.color %></span>
                            <%= s.label.split('—')[1].trim() %>
                        </div>
                    </div>
                    <span class="<%= s.submitted ? 'badge-submitted' : 'badge-pending' %>">
                        <%= s.submitted ? 'Submitted' : 'Pending' %>
                    </span>
                </a>
                <% }); %>
            </div>
        </div>
        <% } %>

        <% if (classSessions.length > 0) { %>
        <div class="att-section">
            <h2>&#127947; Class Attendance</h2>
            <%
                const byPeriod = {};
                classSessions.forEach(function(s) {
                    const k = s.periodNumber;
                    if (!byPeriod[k]) byPeriod[k] = [];
                    byPeriod[k].push(s);
                });
                const periods = Object.keys(byPeriod).map(Number).sort((a,b)=>a-b);
            %>
            <% periods.forEach(function(p) { %>
                <div style="margin-bottom: 14px;">
                    <div style="font-size: 0.78rem; font-weight: 700; color: var(--text-muted); margin-bottom: 6px; text-transform: uppercase;">Period <%= p %></div>
                    <div class="att-grid">
                        <% byPeriod[p].forEach(function(s) { %>
                        <a href="<%= s.link %>" class="att-card">
                            <div class="att-card-label" style="font-size:0.82rem;"><%= s.activityName %></div>
                            <span class="<%= s.submitted ? 'badge-submitted' : 'badge-pending' %>">
                                <%= s.submitted ? 'Submitted' : 'Pending' %>
                            </span>
                        </a>
                        <% }); %>
                    </div>
                </div>
            <% }); %>
        </div>
        <% } %>

        <% if (busSessions.length > 0) { %>
        <div class="att-section">
            <h2>&#128652; Bus Attendance</h2>
            <div class="att-grid">
                <% busSessions.forEach(function(s) { %>
                <a href="<%= s.link %>" class="att-card">
                    <div class="att-card-label"><%= s.label %></div>
                    <span class="<%= s.submitted ? 'badge-submitted' : 'badge-pending' %>">
                        <%= s.submitted ? 'Submitted' : 'Pending' %>
                    </span>
                </a>
                <% }); %>
            </div>
        </div>
        <% } %>

        <% if (extSessions.length > 0) { %>
        <div class="att-section">
            <h2>&#9200; Extended Hours</h2>
            <div class="att-grid">
                <% extSessions.forEach(function(s) { %>
                <a href="<%= s.link %>" class="att-card">
                    <div class="att-card-label"><%= s.label %></div>
                    <span class="<%= s.submitted ? 'badge-submitted' : 'badge-pending' %>">
                        <%= s.submitted ? 'Submitted' : 'Pending' %>
                    </span>
                </a>
                <% }); %>
            </div>
        </div>
        <% } %>
    </div>
</body>
</html>
