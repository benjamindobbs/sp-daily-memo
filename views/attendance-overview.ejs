<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Attendance | Camp Hub</title>
    <link rel="stylesheet" href="/css/style.css">
    <script src="/js/nav.js" defer></script>
</head>
<body>
    <nav class="nav-bar">
        <a href="/" class="nav-btn">&#127968; Hub</a>
        <a href="/master-schedule" class="nav-btn">&#128197; Master Schedule</a>
        <a href="/search" class="nav-btn">&#128269; Camper Lookup</a>
        <a href="/counselor-directory" class="nav-btn">&#128100; Counselors</a>
        <a href="/swap-tool" class="nav-btn">&#128260; Swap Tools</a>
        <a href="/attendance" class="nav-btn primary">&#128203; Attendance</a>
    </nav>

    <div class="container">
        <header style="margin-bottom: 20px;">
            <h1>Daily Attendance</h1>
        </header>

        <div class="date-bar">
            <label for="datePicker">Date:</label>
            <input type="date" id="datePicker" value="<%= date %>" onchange="window.location='/attendance?date='+this.value">
            <input type="text" id="attSearch" class="att-search-input" placeholder="Search counselors or classes…" oninput="filterCards()">
            <% if (lateCount > 0) { %>
                <a href="/attendance/late-arrivals?date=<%= date %>" class="late-warning-link">
                    &#9888; <%= lateCount %> absent this morning &rarr; Late Arrivals
                </a>
            <% } else { %>
                <a href="/attendance/late-arrivals?date=<%= date %>" class="late-arrivals-link">
                    Late Arrivals &rarr;
                </a>
            <% } %>
        </div>

        <%
            // Split sessions by AM/PM
            const hgAM  = homegroupSessions.filter(s => s.session === 'am');
            const hgPM  = homegroupSessions.filter(s => s.session === 'pm');
            const busAM = busSessions.filter(s => s.session === 'am');
            const busPM = busSessions.filter(s => s.session === 'pm');
            const extAM = extSessions.filter(s => s.session === 'am');
            const extPM = extSessions.filter(s => s.session === 'pm');

            // Period map for class sections
            const byPeriod = {};
            classSessions.forEach(function(s) {
                const k = s.periodKey;
                if (!byPeriod[k]) byPeriod[k] = { label: s.periodLabel, sessions: [] };
                byPeriod[k].sessions.push(s);
            });

            // Unique colors for color filter pills
            const hgAMColors = [...new Set(hgAM.map(s => s.color).filter(Boolean))].sort();
            const hgPMColors = [...new Set(hgPM.map(s => s.color).filter(Boolean))].sort();

            // Helper: return badge class + text for section summary
            function secStat(arr) {
                const sub = arr.filter(s => s.submitted).length;
                const tot = arr.length;
                if (tot === 0) return null;
                const cls = sub === tot ? 'sec-count-done' : sub > 0 ? 'sec-count-partial' : 'sec-count-none';
                return { sub, tot, cls };
            }
        %>

        <%/* ── Extended AM ── */%>
        <% if (extAM.length > 0) { %>
        <% const extAMStat = secStat(extAM); %>
        <details class="att-section">
            <summary>
                &#9200; Extended AM
                <% if (extAMStat) { %><span class="sec-count <%= extAMStat.cls %>"><%= extAMStat.sub %>/<%= extAMStat.tot %></span><% } %>
            </summary>
            <div class="att-section-body">
                <div class="att-grid">
                    <% extAM.forEach(function(s) { %>
                    <a href="<%= s.link %>" class="att-card">
                        <div class="att-card-label"><%= s.label %></div>
                        <span class="<%= s.submitted ? 'badge-submitted' : 'badge-pending' %>"><%= s.submitted ? 'Submitted' : 'Pending' %></span>
                    </a>
                    <% }); %>
                </div>
            </div>
        </details>
        <% } %>

        <%/* ── Busses AM ── */%>
        <% if (busAM.length > 0) { %>
        <% const busAMStat = secStat(busAM); %>
        <details class="att-section">
            <summary>
                &#128652; Busses AM
                <% if (busAMStat) { %><span class="sec-count <%= busAMStat.cls %>"><%= busAMStat.sub %>/<%= busAMStat.tot %></span><% } %>
            </summary>
            <div class="att-section-body">
                <div class="att-grid">
                    <% busAM.forEach(function(s) { %>
                    <a href="<%= s.link %>" class="att-card" data-search="<%= ('bus ' + s.route).toLowerCase() %>">
                        <div class="att-card-label"><%= s.label %></div>
                        <span class="<%= s.submitted ? 'badge-submitted' : 'badge-pending' %>"><%= s.submitted ? 'Submitted' : 'Pending' %></span>
                    </a>
                    <% }); %>
                </div>
            </div>
        </details>
        <% } %>

        <%/* ── Home Groups AM ── */%>
        <% if (hgAM.length > 0) { %>
        <% const hgAMStat = secStat(hgAM); %>
        <details class="att-section">
            <summary>
                &#127968; Home Groups AM
                <% if (hgAMStat) { %><span class="sec-count <%= hgAMStat.cls %>"><%= hgAMStat.sub %>/<%= hgAMStat.tot %></span><% } %>
            </summary>
            <div class="att-section-body">
                <% if (hgAMColors.length > 1) { %>
                <div class="color-filter-bar">
                    <button class="pill pill-all active" onclick="setColorFilter('hg-am','all',this)">All</button>
                    <% hgAMColors.forEach(function(c) { %>
                    <button class="pill pill-<%= c %>" onclick="setColorFilter('hg-am','<%= c %>',this)"><%= c %></button>
                    <% }); %>
                </div>
                <% } %>
                <div class="att-grid" data-grid-id="hg-am">
                    <% hgAM.forEach(function(s) { %>
                    <a href="<%= s.link %>" class="att-card" data-search="<%= s.label.toLowerCase() %>" data-color="<%= s.color %>">
                        <div class="att-card-label">
                            <span class="tag <%= s.color %>" style="font-size:0.68rem; padding:1px 7px; margin-right:6px;"><%= s.color %></span>
                            <%= s.label.split('—')[0].trim() %>
                        </div>
                        <span class="<%= s.submitted ? 'badge-submitted' : 'badge-pending' %>"><%= s.submitted ? 'Submitted' : 'Pending' %></span>
                    </a>
                    <% }); %>
                </div>
            </div>
        </details>
        <% } %>

        <%/* ── Class Periods (P1, P2, P3-AM, P3-PM, P4, P5) ── */%>
        <% const periodOrder = ['1','2','3am','3pm','4','5']; %>
        <% periodOrder.forEach(function(pk) { %>
        <% if (byPeriod[pk]) { %>
        <% const pStat = secStat(byPeriod[pk].sessions); %>
        <details class="att-section">
            <summary>
                &#127947; Period <%= byPeriod[pk].label %>
                <% if (pStat) { %><span class="sec-count <%= pStat.cls %>"><%= pStat.sub %>/<%= pStat.tot %></span><% } %>
            </summary>
            <div class="att-section-body">
                <div class="att-grid">
                    <% byPeriod[pk].sessions.forEach(function(s) { %>
                    <a href="<%= s.link %>" class="att-card" data-search="<%= s.activityName.toLowerCase() %>">
                        <div class="att-card-label" style="font-size:0.82rem;"><%= s.activityName %></div>
                        <span class="<%= s.submitted ? 'badge-submitted' : 'badge-pending' %>"><%= s.submitted ? 'Submitted' : 'Pending' %></span>
                    </a>
                    <% }); %>
                </div>
            </div>
        </details>
        <% } %>
        <% }); %>

        <%/* ── Home Groups PM ── */%>
        <% if (hgPM.length > 0) { %>
        <% const hgPMStat = secStat(hgPM); %>
        <details class="att-section">
            <summary>
                &#127968; Home Groups PM
                <% if (hgPMStat) { %><span class="sec-count <%= hgPMStat.cls %>"><%= hgPMStat.sub %>/<%= hgPMStat.tot %></span><% } %>
            </summary>
            <div class="att-section-body">
                <% if (hgPMColors.length > 1) { %>
                <div class="color-filter-bar">
                    <button class="pill pill-all active" onclick="setColorFilter('hg-pm','all',this)">All</button>
                    <% hgPMColors.forEach(function(c) { %>
                    <button class="pill pill-<%= c %>" onclick="setColorFilter('hg-pm','<%= c %>',this)"><%= c %></button>
                    <% }); %>
                </div>
                <% } %>
                <div class="att-grid" data-grid-id="hg-pm">
                    <% hgPM.forEach(function(s) { %>
                    <a href="<%= s.link %>" class="att-card" data-search="<%= s.label.toLowerCase() %>" data-color="<%= s.color %>">
                        <div class="att-card-label">
                            <span class="tag <%= s.color %>" style="font-size:0.68rem; padding:1px 7px; margin-right:6px;"><%= s.color %></span>
                            <%= s.label.split('—')[0].trim() %>
                        </div>
                        <span class="<%= s.submitted ? 'badge-submitted' : 'badge-pending' %>"><%= s.submitted ? 'Submitted' : 'Pending' %></span>
                    </a>
                    <% }); %>
                </div>
            </div>
        </details>
        <% } %>

        <%/* ── Busses PM ── */%>
        <% if (busPM.length > 0) { %>
        <% const busPMStat = secStat(busPM); %>
        <details class="att-section">
            <summary>
                &#128652; Busses PM
                <% if (busPMStat) { %><span class="sec-count <%= busPMStat.cls %>"><%= busPMStat.sub %>/<%= busPMStat.tot %></span><% } %>
            </summary>
            <div class="att-section-body">
                <div class="att-grid">
                    <% busPM.forEach(function(s) { %>
                    <a href="<%= s.link %>" class="att-card" data-search="<%= ('bus ' + s.route).toLowerCase() %>">
                        <div class="att-card-label"><%= s.label %></div>
                        <span class="<%= s.submitted ? 'badge-submitted' : 'badge-pending' %>"><%= s.submitted ? 'Submitted' : 'Pending' %></span>
                    </a>
                    <% }); %>
                </div>
            </div>
        </details>
        <% } %>

        <%/* ── Extended PM ── */%>
        <% if (extPM.length > 0) { %>
        <% const extPMStat = secStat(extPM); %>
        <details class="att-section">
            <summary>
                &#9200; Extended PM
                <% if (extPMStat) { %><span class="sec-count <%= extPMStat.cls %>"><%= extPMStat.sub %>/<%= extPMStat.tot %></span><% } %>
            </summary>
            <div class="att-section-body">
                <div class="att-grid">
                    <% extPM.forEach(function(s) { %>
                    <a href="<%= s.link %>" class="att-card">
                        <div class="att-card-label"><%= s.label %></div>
                        <span class="<%= s.submitted ? 'badge-submitted' : 'badge-pending' %>"><%= s.submitted ? 'Submitted' : 'Pending' %></span>
                    </a>
                    <% }); %>
                </div>
            </div>
        </details>
        <% } %>

    </div>

    <script>
        const activeColorFilters = { 'hg-am': 'all', 'hg-pm': 'all' };

        function filterCards() {
            const term = document.getElementById('attSearch').value.toLowerCase().trim();

            if (term) {
                // Search mode: show all matching cards; ignore color filters
                document.querySelectorAll('.att-card[data-search]').forEach(card => {
                    card.style.display = card.dataset.search.includes(term) ? '' : 'none';
                });
                // Auto-expand sections that have at least one visible result
                document.querySelectorAll('.att-section').forEach(section => {
                    const hasVisible = [...section.querySelectorAll('.att-card[data-search]')]
                        .some(c => c.style.display !== 'none');
                    if (hasVisible) section.open = true;
                });
            } else {
                // Clear search: show everything, then re-apply color filters
                document.querySelectorAll('.att-card[data-search]').forEach(card => {
                    card.style.display = '';
                });
                ['hg-am', 'hg-pm'].forEach(gridId => {
                    const color = activeColorFilters[gridId];
                    if (color !== 'all') {
                        document.querySelectorAll(`[data-grid-id="${gridId}"] .att-card`).forEach(card => {
                            card.style.display = card.dataset.color === color ? '' : 'none';
                        });
                    }
                });
            }
        }

        function setColorFilter(gridId, color, btn) {
            activeColorFilters[gridId] = color;
            btn.closest('.color-filter-bar').querySelectorAll('.pill').forEach(p => p.classList.remove('active'));
            btn.classList.add('active');
            document.querySelectorAll(`[data-grid-id="${gridId}"] .att-card`).forEach(card => {
                card.style.display = (color === 'all' || card.dataset.color === color) ? '' : 'none';
            });
        }

        document.getElementById('attSearch').addEventListener('focus', function() {
            this.style.borderColor = 'var(--primary)';
        });
        document.getElementById('attSearch').addEventListener('blur', function() {
            this.style.borderColor = '#cbd5e1';
        });
    </script>
</body>
</html>
