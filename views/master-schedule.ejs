<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Master Schedule | Camp Hub</title>
    <link rel="stylesheet" href="/css/style.css">
    <script src="/js/nav.js" defer></script>
</head>
<body>

    <nav class="nav-bar">
        <a href="/" class="nav-btn">🏠 Hub</a>
        <a href="/search" class="nav-btn">🔍 Camper Lookup</a>
        <a href="/counselor-directory" class="nav-btn">👤 Counselors</a>
        <a href="/master-schedule" class="nav-btn primary">📅 Master Schedule</a>
        <a href="/swap-tool" class="nav-btn">🔄 Swap Tools</a>
        <a href="/promotions" class="nav-btn">🔔 Promotions</a>
        <a href="/attendance" class="nav-btn">&#128203; Attendance</a>
    </nav>

    <div class="container-xl">
        <header style="margin-bottom: 24px;">
            <h1>Master Schedule</h1>
            <p style="color: var(--text-muted); margin: 0;">All classes by period. Click a class name to view its full roster.</p>
        </header>

        <div class="filter-bar">
            <label for="periodFilter">Period:</label>
            <select id="periodFilter" class="filter-dropdown" onchange="applyFilters()">
                <option value="all">All Periods</option>
                <% for (let p = 1; p <= 6; p++) { %>
                    <% if (p === 3) { %>
                        <option value="3 AM">Period 3 AM</option>
                        <option value="3 PM">Period 3 PM</option>
                    <% } else { %>
                        <option value="<%= p %>">Period <%= p %></option>
                    <% } %>
                <% } %>
            </select>

            <label for="sideFilter" style="margin-left: 10px;">Side:</label>
            <select id="sideFilter" class="filter-dropdown" onchange="applyFilters()">
                <option value="all">All</option>
                <option value="Sports">Sports</option>
                <option value="Enrichment">Enrichment</option>
            </select>

            <label for="groupFilter" style="margin-left: 10px;">Group:</label>
            <select id="groupFilter" class="filter-dropdown" onchange="applyFilters()">
                <option value="all">All Groups</option>
                <option value="Red">Red</option>
                <option value="Carolina">Carolina</option>
                <option value="Green">Green</option>
                <option value="Navy">Navy</option>
            </select>
        </div>

        <% schedule.forEach(function(period) { %>
        <div class="period-section" data-period="<%= period.periodLabel %>">
            <div class="period-header">
                <span class="period-badge">Period <%= period.periodLabel %></span>
                <div class="period-divider"></div>
                <span style="font-size: 0.8rem; color: var(--text-muted); white-space: nowrap;"><%= period.classes.length %> classes</span>
            </div>

            <table class="class-table">
                <thead>
                    <tr>
                        <th style="width: 22%;">Class</th>
                        <th style="width: 8%;">Side</th>
                        <th style="width: 9%;">Enrolled</th>
                        <th style="width: 16%;">Groups</th>
                        <th style="width: 13%;">Staff</th>
                        <th style="width: 10%;">Location</th>
                        <th>Counselors</th>
                    </tr>
                </thead>
                <tbody>
                    <% period.classes.forEach(function(cls) { %>
                    <tr class="class-row"
                        data-side="<%= cls.sideOfCamp || '' %>"
                        data-groups="<%= cls.colorGroups.join(',') %>">

                        <td>
                            <a class="activity-link"
                               href="/class-roster/<%= period.periodNumber %>/<%= encodeURIComponent(cls.activityName) %>">
                                <%= cls.activityName %>
                            </a>
                        </td>

                        <td>
                            <% if (cls.sideOfCamp === 'Sports') { %>
                                <span class="side-pill side-sports">Sports</span>
                            <% } else if (cls.sideOfCamp === 'Enrichment') { %>
                                <span class="side-pill side-enrichment">Enrichment</span>
                            <% } else { %>
                                <span class="side-pill" style="background:#f1f5f9; color:#64748b;">—</span>
                            <% } %>
                        </td>

                        <td>
                            <%
                                const pct = cls.maxCapacity ? cls.enrolled / cls.maxCapacity : 0;
                                let enrollClass = '';
                                if (pct >= 1) enrollClass = 'full';
                                else if (pct >= 0.85) enrollClass = 'near-full';
                            %>
                            <span class="enroll-badge <%= enrollClass %>">
                                <%= cls.enrolled %><% if (cls.maxCapacity) { %>/<%= cls.maxCapacity %><% } %>
                            </span>
                        </td>

                        <td>
                            <div class="group-dots">
                                <% cls.colorGroups.forEach(function(color) { %>
                                    <span class="tag <%= color %>"><%= color %></span>
                                <% }); %>
                                <% if (cls.colorGroups.length === 0) { %>
                                    <span style="color: var(--text-muted); font-size: 0.8rem;">—</span>
                                <% } %>
                            </div>
                        </td>

                        <td>
                            <% if (cls.staff.length > 0) { %>
                                <% cls.staff.forEach(function(s) { %>
                                    <a href="/staff-lookup?name=<%= encodeURIComponent(s.FirstName + ' ' + s.LastName) %>" class="staff-link">
                                        <div class="staff-name-sched"><%= s.FirstName %> <%= s.LastName %></div>
                                        <div class="staff-type-label"><%= s.StaffType %></div>
                                    </a>
                                <% }); %>
                            <% } else { %>
                                <span style="color: var(--text-muted); font-size: 0.8rem;">—</span>
                            <% } %>
                        </td>

                        <td>
                            <span class="location-text"><%= cls.location || '—' %></span>
                        </td>

                        <td>
                            <div class="counselor-chips">
                                <% cls.counselors.forEach(function(c) { %>
                                    <a href="/counselor-profile/<%= c.CounselorID %>"
                                       class="counselor-chip <%= c.HomeGroupColor %>">
                                        <%= c.FirstName %> <%= c.LastName %>
                                    </a>
                                <% }); %>
                                <% if (cls.counselors.length === 0) { %>
                                    <span style="color: var(--text-muted); font-size: 0.8rem;">—</span>
                                <% } %>
                            </div>
                        </td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
        <% }); %>
    </div>

    <script>
        function applyFilters() {
            const period = document.getElementById('periodFilter').value;
            const side   = document.getElementById('sideFilter').value;
            const group  = document.getElementById('groupFilter').value;

            // Show/hide whole period sections
            document.querySelectorAll('.period-section').forEach(section => {
                const sectionPeriod = section.dataset.period;
                const periodMatch = period === 'all' || sectionPeriod === period;
                section.style.display = periodMatch ? '' : 'none';
            });

            // Show/hide individual rows within visible sections
            document.querySelectorAll('.class-row').forEach(row => {
                const sideMatch  = side  === 'all' || row.dataset.side  === side;
                const groupMatch = group === 'all' || row.dataset.groups.split(',').includes(group);
                row.style.display = (sideMatch && groupMatch) ? '' : 'none';
            });
        }
    </script>
</body>
</html>
