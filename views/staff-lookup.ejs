<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Staff Lookup | Camp Hub</title>
    <link rel="stylesheet" href="/css/style.css">
    <script src="/js/nav.js" defer></script>
</head>
<body>
    <nav class="nav-bar">
        <a href="/" class="nav-btn">&#127968; Hub</a>
        <a href="/master-schedule" class="nav-btn">&#128197; Master Schedule</a>
        <a href="/search" class="nav-btn">&#128269; Camper Lookup</a>
        <a href="/counselor-directory" class="nav-btn">&#128100; Counselors</a>
        <a href="/staff-lookup" class="nav-btn primary">&#128101; Staff Lookup</a>
        <a href="/swap-tool" class="nav-btn">&#128260; Swap Tools</a>
        <a href="/attendance" class="nav-btn">&#128203; Attendance</a>
    </nav>

    <div class="container">
        <div class="search-header">
            <h1 style="margin: 0;">Staff Lookup</h1>
            <p style="color: var(--text-muted); margin: 6px 0 0;">Find staff schedules, activities, and locations.</p>
            <div class="search-bar-container">
                <input type="text" id="staffSearch" class="search-input"
                    placeholder="Type a name (e.g. 'Johnson' or 'Mike')…" oninput="runSearch()"
                    value="<%= query %>">
                <button class="btn" style="background: #f1f5f9; color: #475569;" onclick="clearSearch()">Clear</button>
            </div>
        </div>

        <% if (staff.length === 0) { %>
            <div style="background: white; border-radius: 12px; box-shadow: var(--shadow); border: 1px solid var(--border-color);">
                <div class="no-results">No staff records found. Import staff data in Settings.</div>
            </div>
        <% } else { %>

        <%
            // Group by StaffType for section headers
            const groups = [];
            let lastType = null;
            staff.forEach(function(s) {
                if (s.StaffType !== lastType) {
                    groups.push({ type: s.StaffType || 'Other', members: [] });
                    lastType = s.StaffType;
                }
                groups[groups.length - 1].members.push(s);
            });

            // Periods that could have data
            const PERIODS = [1, 2, 3, 4, 5, 6];
        %>

        <div class="table-scroll">
        <table class="staff-table" id="staffTable">
            <thead>
                <tr>
                    <th style="width: 180px;">Name</th>
                    <th style="width: 110px;">Type</th>
                    <th>Schedule</th>
                </tr>
            </thead>
            <tbody>
            <% groups.forEach(function(group) { %>
                <tr class="type-group-header" data-group-header>
                    <td colspan="3"><%= group.type %></td>
                </tr>
                <% group.members.forEach(function(s) { %>
                <tr class="staff-row" data-name="<%= (s.FirstName + ' ' + s.LastName).toLowerCase() %>">
                    <td>
                        <div class="staff-name"><%= s.FirstName %> <%= s.LastName %></div>
                    </td>
                    <td>
                        <span class="staff-type-badge"><%= s.StaffType || '—' %></span>
                    </td>
                    <td>
                        <div class="mini-sched">
                        <% PERIODS.forEach(function(p) { %>
                            <% if (s['P' + p]) { %>
                            <div class="period-pill">
                                <div class="period-pill-label">Period <%= p %></div>
                                <div class="period-pill-activity"><%= s['P' + p] %></div>
                                <% if (s['L' + p]) { %>
                                <div class="period-pill-location">&#128205; <%= s['L' + p] %></div>
                                <% } %>
                            </div>
                            <% } %>
                        <% }); %>
                        <% if (!PERIODS.some(function(p) { return s['P' + p]; })) { %>
                            <span style="color: var(--text-muted); font-style: italic; font-size: 0.85rem;">No schedule assigned</span>
                        <% } %>
                        </div>
                    </td>
                </tr>
                <% }); %>
            <% }); %>
            </tbody>
        </table>

        </div><!-- /table-scroll -->

        <div id="noResults" style="display:none; background: white; border-radius: 12px; box-shadow: var(--shadow); border: 1px solid var(--border-color);">
            <div class="no-results">No staff members found matching your search.</div>
        </div>

        <% } %>
    </div>

    <script>
        function runSearch() {
            const term = document.getElementById('staffSearch').value.trim().toLowerCase();
            const rows = document.querySelectorAll('.staff-row');
            const headers = document.querySelectorAll('[data-group-header]');
            let totalVisible = 0;

            // Track which group headers have visible members
            const visibleGroups = new Set();

            rows.forEach(function(row) {
                const name = row.getAttribute('data-name');
                const show = term === '' || name.includes(term);
                row.style.display = show ? '' : 'none';
                if (show) {
                    totalVisible++;
                    // Find the preceding group header
                    let prev = row.previousElementSibling;
                    while (prev) {
                        if (prev.hasAttribute('data-group-header')) {
                            visibleGroups.add(prev);
                            break;
                        }
                        prev = prev.previousElementSibling;
                    }
                }
            });

            // Show/hide group headers based on whether any member is visible
            headers.forEach(function(h) {
                h.style.display = visibleGroups.has(h) ? '' : 'none';
            });

            const noResults = document.getElementById('noResults');
            if (noResults) noResults.style.display = totalVisible === 0 ? '' : 'none';
        }

        function clearSearch() {
            document.getElementById('staffSearch').value = '';
            runSearch();
            document.getElementById('staffSearch').focus();
        }
    </script>
</body>
</html>
